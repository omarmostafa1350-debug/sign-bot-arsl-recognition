[Unit]
Description=Sign-Bot PyQt5 Dashboard (kiosk)
After=graphical.target

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/home/pi/Desktop/signbot_dashboard
ExecStart=/usr/bin/python3 /home/pi/Desktop/signbot_dashboard/main.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
